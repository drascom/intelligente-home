# Test sunucusu prod override'ları. /etc/intelligente-home/brain.env'e kopyalanır,
# brain.service EnvironmentFile= ile yükler. Bunlar commit'li mate-brain/.env'i
# EZER (pydantic-settings: env-var > .env dosyası), böylece git pull dokunmaz.
# CHANGE_ME alanlarını gerçek değerlerle doldur.

# LLM: native vLLM (:8000). Paylaşımlı GPU → 7B-AWQ (vllm.service ile uyumlu olsun).
LLM_BACKEND=vllm
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
LLM_TEMPERATURE=0.3

BRAIN_PORT=8800
BRAIN_DB_PATH=/opt/intelligente-home/mate-brain/brain.db
BRAIN_ADMIN_TOKEN=CHANGE_ME

# Home Assistant (gerçek)
HA_URL=https://home.drascom.uk
HA_TOKEN=CHANGE_ME

# Ses düzlemi (native, localhost)
STT_HOST=localhost
STT_PORT=10300
STT_LANGUAGE=tr
TTS_ENGINE=vox
VOX_HOST=localhost
VOX_PORT=8808
VOX_STANDARD_VOICE=nese

# MQTT (zigbee2mqtt broker). NOT: Mac dev brain ile AYNI ANDA çalışırsa
# identifier="brain" çakışır — test ve dev'i aynı anda çalıştırma.
MQTT_HOST=192.168.0.90
MQTT_PORT=1883
MQTT_USERNAME=brain
MQTT_PASSWORD=CHANGE_ME

# Dashboard CORS (mate-dash dev origin'leri)
MONITOR_CORS_ORIGINS=http://localhost:5173,http://192.168.0.25:5173

SATELLITES=
FCM_CREDENTIALS_PATH=
