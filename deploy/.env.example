# ---- vLLM ----
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
VLLM_MAX_MODEL_LEN=16384
VLLM_GPU_UTIL=0.85
VLLM_TOOL_PARSER=hermes
HF_TOKEN=

# ---- Voice ----
WHISPER_MODEL=medium-int8
WHISPER_LANGUAGE=tr
PIPER_VOICE=tr_TR-fettah-medium
WAKE_WORD=ok_nabu

# ---- Brain ----
BRAIN_PORT=8800
BRAIN_DB_PATH=/data/brain.db
BRAIN_ADMIN_TOKEN=change-me-long-random-string
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# Home Assistant connection (create a long-lived token for user `brain`)
# HA is the smart-home connector only — if it's down, chat and voice keep working.
HA_URL=http://homeassistant:8123
HA_TOKEN=

# ---- Voice plane (brain-direct; HA not in the path) ----
STT_HOST=whisper
STT_PORT=10300
STT_LANGUAGE=tr
# Brain TTS: vox (VoxCPM2, primary) or piper (fallback / HA Voice PE path)
TTS_ENGINE=vox
VOX_HOST=vox
VOX_PORT=8808
VOX_API_KEY=
VOX_STANDARD_VOICE=nese
TTS_HOST=piper
TTS_PORT=10200
# wyoming-satellite nodes the brain connects to: name@host[:port], comma-separated
SATELLITES=

# MQTT (brain's own credentials)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=brain
MQTT_PASSWORD=

# FCM push (opsiyonel): service-account JSON yolu; bos = dry-run
FCM_CREDENTIALS_PATH=
