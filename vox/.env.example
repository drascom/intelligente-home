# Vox TTS bridge ortam değişkenleri — kopyala ".env" yap, secret'ı doldur.
# .env asla commit edilmez (.gitignore'da). Deploy rsync'i de bunu hariç tutar
# (deploy.sh: --exclude '.env'), yani VPS'teki sürüm üzerine yazılmaz.
#
# Yüklemek için: systemd unit'te EnvironmentFile=-/opt/vox/.env tanımlı.
# Değiştirdikten sonra: systemctl restart vox-tts

# HTTP'de "Authorization: Bearer <KEY>", WS'te "?token=<KEY>" ile karşılaştırılır.
# Boş bırakırsan auth devre dışı (endpoint herkese açık).
VOX_API_KEY=benimsecrettokenim
