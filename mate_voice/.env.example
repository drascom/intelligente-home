# mate_voice plugin — ortam değişkenleri ŞABLONU
#
# Hermes `hermes plugins install` sırasında bu dosyayı `.env`'e KOPYALAR
# (_copy_example_files). Değerleri `.env`'de doldur. `.env` gitignore'da; bu
# şablon (.env.example) commit'lenir. Plugin kendi .env'ini yükler (voice/config.py)
# — global ~/.hermes/.env değerlerini EZMEZ, yalnız boşları doldurur.
#
# "gerekli her şey plugin klasöründe": env burada, deps self-install (requirements.txt),
# speaker modeli auto-download (~/.hermes/mate_voice/campplus.onnx).

# ── LiveKit (ZORUNLU) ───────────────────────────────────────────────────────
# Agent'ın bağlandığı LiveKit sunucusu + server-side JWT için anahtarlar.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=            # /etc/livekit/livekit.yaml'deki secret — BOŞSA plugin bağlanmaz
# İstemcilere dönülen public wss URL (istemci iç ws://127.0.0.1'e erişemez):
MATE_PUBLIC_LIVEKIT_URL=wss://mate-livekit.drascom.uk
# Agent'ın katıldığı oda (onboarding/demo de buraya düşer):
MATE_LIVEKIT_ROOM=mate-hermes-test

# ── STT (whisper, Wyoming) — ZORUNLU ────────────────────────────────────────
STT_HOST=192.168.0.25
STT_PORT=10300
STT_LANGUAGE=tr                # tr/en; boş = istemci attribute / auto
# Opsiyonel alt motor (nemotron):
# STT_NEMOTRON_HOST=192.168.0.25
# STT_NEMOTRON_PORT=10301

# ── TTS (vox) — ZORUNLU ─────────────────────────────────────────────────────
TTS_ENGINE=vox
VOX_HOST=192.168.0.25
VOX_PORT=8808
# VOX_API_KEY=

# ── İstemci token endpoint (ZORUNLU: paylaşılan anahtar) ────────────────────
# İstemcilerin X-Mate-Key ile gönderdiği anahtar (openssl rand -hex 24).
# BOŞSA authenticated /mate/token kapalı; sadece key'siz /mate/demo-token çalışır.
MATE_VOICE_CLIENT_KEY=
MATE_VOICE_TOKEN_PORT=8830
MATE_VOICE_TOKEN_BIND=0.0.0.0
MATE_VOICE_CLIENT_TOKEN_TTL=3600
# Dev/test: odadaki herkes konuşabilsin:
MATE_VOICE_ALLOW_ALL_USERS=true

# ── Onboarding / demo token (key'siz sıfır-konfig) ──────────────────────────
# MATE_ONBOARDING_ROOM=            # boş = MATE_LIVEKIT_ROOM
MATE_VOICE_DEMO_TOKEN_ENABLED=true
MATE_VOICE_DEMO_TOKEN_TTL=600

# ── Speaker-ID / enrollment ─────────────────────────────────────────────────
SPEAKER_ID_ENABLED=true
# Model: boşsa plugin campplus.onnx'u ~/.hermes/mate_voice/'e indirir (auto).
# SPEAKER_MODEL_PATH=
# MATE_SPEAKER_MODEL_URL=          # özel model URL'i (varsayılan: sherpa-onnx release)
SPEAKER_MODEL_ID=campplus_zh_en_advanced_v1
SPEAKER_THRESHOLD=0.45
SPEAKER_MARGIN=0.05
SPEAKER_MIN_SECONDS=1.0
# MATE_VOICE_DB_PATH=             # boş = ~/.hermes/mate_voice/speakers.db

# ── Smart-turn v3 EOU ───────────────────────────────────────────────────────
TURN_DETECTOR_ENABLED=true
TURN_DETECTOR_THRESHOLD=0.5

# ── Diğer ───────────────────────────────────────────────────────────────────
# MATE_HOME_CHANNEL=               # proaktif teslim hedefi; boşsa plugin oda'yı auto-sethome yapar
MATE_VOICE_AUTO_INSTALL_DEPS=1     # 0 = deps self-install kapalı
