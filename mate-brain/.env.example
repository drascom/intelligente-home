# Dev server (this Mac). The real Linux server uses deploy/.env.example values.
BRAIN_PORT=8800
BRAIN_DB_PATH=brain-dev.db
BRAIN_ADMIN_TOKEN=change-me

# Dev: pi agent (Codex subscription) instead of vLLM
LLM_BACKEND=pi
PI_MODEL=openai-codex/gpt-5.5

# Home Assistant
HA_URL=https://your-ha-instance.example.com
HA_TOKEN=your-long-lived-access-token

STT_HOST=localhost
STT_PORT=10300
STT_LANGUAGE=tr
TTS_HOST=localhost
TTS_PORT=10200
SATELLITES=salon@salon.local:10700

# MQTT management plane (mosquitto on the zigbee2mqtt server)
MQTT_HOST=192.168.0.x
MQTT_PORT=1883
MQTT_USERNAME=your-mqtt-user
MQTT_PASSWORD=your-mqtt-password
