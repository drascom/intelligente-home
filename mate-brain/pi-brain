#!/bin/sh
# Interactive "chat with the house" using the PROJECT-LOCAL pi (not the global
# one): pinned binary, no global extensions/skills, sessions stored in .pi/.
# The brain server must be running (python -m brain.main) for tools to work.
cd "$(dirname "$0")"
set -a; [ -f .env ] && . ./.env; set +a
export BRAIN_API_URL="http://127.0.0.1:${BRAIN_PORT:-8800}"
export BRAIN_API_TOKEN="${BRAIN_ADMIN_TOKEN}"
exec ./node_modules/.bin/pi \
  --provider "${PI_MODEL%%/*}" \
  --model "${PI_MODEL:-openai-codex/gpt-5.5}" \
  --session-dir .pi/sessions \
  --no-extensions --no-skills --no-prompt-templates --no-context-files \
  --no-builtin-tools \
  -e brain/pi/ha-tools.ts \
  --system-prompt "You are the home assistant brain for this household. You can see and control every device through your tools. Be brief and natural; answer in the language the user used. You are not a coding assistant." \
  "$@"
