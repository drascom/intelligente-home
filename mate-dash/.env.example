# mate-dash bağlantı varsayılanları (build-zamanı, Vite).
# Gerçek değerler için: mate-dash/.env (gitignore'lu) — sunucuda dururlar,
# her build'de gömülür. Burada set'liyse formdan/localStorage'dan ÖNCELİKLİdir.

VITE_BRAIN_URL=http://192.168.0.25:8800
# Admin token'ı buraya koyarsan derlenmiş JS'e gömülür → dashboard'ı açan
# herkes (LAN'da) bu token'ı görebilir. Boş bırakırsan formdan girilir (önerilen).
VITE_BRAIN_TOKEN=
